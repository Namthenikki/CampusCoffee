# Copy this file to .env.local and fill in the values from your Supabase project.
# Supabase dashboard → Project Settings → API

# Project URL (looks like https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# "anon" / "public" key — safe to expose to the browser (RLS protects the data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# "service_role" key — SERVER ONLY. Bypasses all row-level security.
# Never prefix this with NEXT_PUBLIC_ and never paste it into client code.
SUPABASE_SERVICE_ROLE_KEY=

# The fixed campus email domain. Students type only the part before the @.
NEXT_PUBLIC_EMAIL_DOMAIN=muj.manipal.edu

# Subdomain that receives student verification emails (Brevo inbound parsing).
# Must differ from the domain you send from.
NEXT_PUBLIC_INBOUND_DOMAIN=reply.campuscoffee.online

# Shared secret guarding the inbound webhook. Any long random string.
VERIFY_WEBHOOK_SECRET=

# Brevo API key (SMTP & API -> API keys tab). Only needed to register the
# inbound webhook once; not used at runtime.
BREVO_API_KEY=
